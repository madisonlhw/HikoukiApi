@HikoukiApi_HostAddress = http://localhost:5211

### AircraftTypeCodes — list all
GET {{HikoukiApi_HostAddress}}/aircrafttypecodes
Accept: application/json

### AircraftTypeCodes — get one
GET {{HikoukiApi_HostAddress}}/aircrafttypecodes/1
Accept: application/json

### AircraftTypeCodes — create
POST {{HikoukiApi_HostAddress}}/aircrafttypecodes
Content-Type: application/json

{
  "icao": "B738",
  "manufacturer": "Boeing"
}

### AircraftTypeCodes — update
PUT {{HikoukiApi_HostAddress}}/aircrafttypecodes/1
Content-Type: application/json

{
  "id": 1,
  "icao": "B739",
  "manufacturer": "Boeing"
}

### AircraftTypeCodes — delete
DELETE {{HikoukiApi_HostAddress}}/aircrafttypecodes/1

### Variants — list all for a parent
GET {{HikoukiApi_HostAddress}}/aircrafttypecodes/3/variants
Accept: application/json

### Variants — get one
GET {{HikoukiApi_HostAddress}}/aircrafttypecodes/1/variants/1
Accept: application/json

### Variants — create
POST {{HikoukiApi_HostAddress}}/aircrafttypecodes/3/variants
Content-Type: application/json

{
  "variantName": "737-800WL"
}

### Variants — update
PUT {{HikoukiApi_HostAddress}}/aircrafttypecodes/1/variants/1
Content-Type: application/json

{
  "variantName": "737-900"
}

### Variants — delete
DELETE {{HikoukiApi_HostAddress}}/aircrafttypecodes/1/variants/1

### Airports — list all
